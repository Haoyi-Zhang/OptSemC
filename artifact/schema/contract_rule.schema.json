{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OptSem-C contract rule",
  "type": "object",
  "required": [
    "rule_id",
    "engine",
    "guard",
    "action",
    "state",
    "version",
    "evidence",
    "confidence"
  ],
  "properties": {
    "rule_id": {
      "type": "string"
    },
    "engine": {
      "type": "string"
    },
    "guard": {
      "type": "object",
      "additionalProperties": true
    },
    "action": {
      "type": "object",
      "required": [
        "operator",
        "kind",
        "layer",
        "placement",
        "decision_time",
        "observability"
      ],
      "properties": {
        "operator": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "layer": {
          "type": "string"
        },
        "placement": {
          "type": "string"
        },
        "decision_time": {
          "type": "string"
        },
        "observability": {
          "type": "string"
        }
      }
    },
    "state": {
      "enum": [
        "MUST",
        "MAY",
        "MUST_NOT",
        "UNSPEC"
      ]
    },
    "version": {
      "type": "object"
    },
    "evidence": {
      "type": "object",
      "required": [
        "source_id",
        "source_class"
      ],
      "properties": {
        "source_id": {
          "type": "string"
        },
        "segment_id": {
          "type": "string"
        },
        "source_class": {
          "type": "string"
        }
      }
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}